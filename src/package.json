{
	"name": "roxonn-code",
	"displayName": "Roxonn Code",
	"description": "AI-powered coding assistant with crypto payments",
	"publisher": "roxonn",
	"version": "0.1.0",
	"icon": "assets/icons/roxn.png",
	"galleryBanner": {
		"color": "#FFFFFF",
		"theme": "light"
	},
	"engines": {
		"vscode": "^1.84.0",
		"node": "20.18.1"
	},
	"author": {
		"name": "Roxonn"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/roxonn/roxonn-code"
	},
	"homepage": "https://roxonn.com",
	"categories": [
		"AI",
		"Chat",
		"Programming Languages",
		"Education",
		"Snippets",
		"Testing"
	],
	"keywords": [
		"cline",
		"claude",
		"dev",
		"mcp",
		"openrouter",
		"coding",
		"agent",
		"autonomous",
		"chatgpt",
		"sonnet",
		"ai",
		"llama",
		"Roxonn Code",
		"Roxonn",
		"roxonncode",
		"crypto"
	],
	"activationEvents": [
		"onLanguage",
		"onStartupFinished"
	],
	"main": "./dist/extension.js",
	"contributes": {
		"walkthroughs": [
			{
				"id": "roxonnCodeWalkthrough",
				"title": "5 ways Roxonn Code helps you code",
				"description": "You now have a personal AI coding assistant.",
				"steps": [
					{
						"id": "welcome",
						"title": "Write code for you",
						"description": "Describe what you want to build. Roxonn Code will write it from scratch, generate the files, and run them for you.",
						"media": {
							"markdown": "walkthrough/step1.md"
						}
					},
					{
						"id": "getting-started",
						"title": "Understand your codebase",
						"description": "Need clarity on how something works? Ask Roxonn Code about any part of your files and get a clear explanation.",
						"media": {
							"markdown": "walkthrough/step2.md"
						},
						"content": {
							"path": "walkthrough/step2.md"
						}
					},
					{
						"id": "modes",
						"title": "Get things working again",
						"description": "Stuck on an error? Roxonn Code can find the issue, fix it, and get your code running.",
						"media": {
							"markdown": "walkthrough/step3.md"
						}
					},
					{
						"id": "code-actions",
						"title": "Plan your logic",
						"description": "Not sure where to start? Map out your logic and structure before writing a single line of code.",
						"media": {
							"markdown": "walkthrough/step4.md"
						}
					},
					{
						"id": "advanced-features",
						"title": "And more",
						"description": "Improve your prompt, add context, or create your own custom modes.",
						"media": {
							"markdown": "walkthrough/step5.md"
						}
					}
				]
			}
		],
		"viewsContainers": {
			"activitybar": [
				{
					"id": "roxonn-code-ActivityBar",
					"title": "%views.activitybar.title%",
					"icon": "assets/icons/roxn.png",
					"when": "isMac"
				}
			]
		},
		"views": {
			"roxonn-code-ActivityBar": [
				{
					"type": "webview",
					"id": "roxonn-code.SidebarProvider",
					"name": "%views.sidebar.name%"
				}
			]
		},
		"commands": [
			{
				"command": "roxonn-code.plusButtonClicked",
				"title": "%command.newTask.title%",
				"icon": "$(add)"
			},
			{
				"command": "roxonn-code.importSettings",
				"title": "Import Settings",
				"category": "%configuration.title%"
			},
			{
				"command": "roxonn-code.exportSettings",
				"title": "Export Settings",
				"category": "%configuration.title%"
			},
			{
				"command": "roxonn-code.promptsButtonClicked",
				"title": "%command.prompts.title%",
				"icon": "$(notebook)"
			},
			{
				"command": "roxonn-code.historyButtonClicked",
				"title": "%command.history.title%",
				"icon": "$(history)"
			},
			{
				"command": "roxonn-code.popoutButtonClicked",
				"title": "%command.openInEditor.title%",
				"icon": "$(link-external)"
			},
			{
				"command": "roxonn-code.settingsButtonClicked",
				"title": "%command.settings.title%",
				"icon": "$(settings-gear)"
			},
			{
				"command": "roxonn-code.helpButtonClicked",
				"title": "%command.documentation.title%",
				"icon": "$(question)"
			},
			{
				"command": "roxonn-code.openInNewTab",
				"title": "%command.openInNewTab.title%",
				"category": "%configuration.title%"
			},
			{
				"command": "roxonn-code.explainCode",
				"title": "%command.explainCode.title%",
				"category": "%configuration.title%"
			},
			{
				"command": "roxonn-code.fixCode",
				"title": "%command.fixCode.title%",
				"category": "%configuration.title%"
			},
			{
				"command": "roxonn-code.improveCode",
				"title": "%command.improveCode.title%",
				"category": "%configuration.title%"
			},
			{
				"command": "roxonn-code.addToContext",
				"title": "%command.addToContext.title%",
				"category": "%configuration.title%"
			},
			{
				"command": "roxonn-code.newTask",
				"title": "%command.newTask.title%",
				"category": "%configuration.title%"
			},
			{
				"command": "roxonn-code.terminalAddToContext",
				"title": "%command.terminal.addToContext.title%",
				"category": "%extension.displayName%"
			},
			{
				"command": "roxonn-code.terminalFixCommand",
				"title": "%command.terminal.fixCommand.title%",
				"category": "%extension.displayName%"
			},
			{
				"command": "roxonn-code.terminalExplainCommand",
				"title": "%command.terminal.explainCommand.title%",
				"category": "%extension.displayName%"
			},
			{
				"command": "roxonn-code.setCustomStoragePath",
				"title": "%command.setCustomStoragePath.title%",
				"category": "%configuration.title%"
			},
			{
				"command": "roxonn-code.focusChatInput",
				"title": "%command.focusInput.title%",
				"category": "%configuration.title%"
			},
			{
				"command": "roxonn-code.acceptInput",
				"title": "%command.acceptInput.title%",
				"category": "%configuration.title%"
			},
			{
				"command": "roxonn-code.profileButtonClicked",
				"title": "%command.profile.title%",
				"icon": "$(account)",
				"category": "%configuration.title%"
			}
		],
		"keybindings": [
			{
				"command": "roxonn-code.focusChatInput",
				"key": "ctrl+shift+a",
				"mac": "cmd+shift+a",
				"when": "true"
			},
			{
				"command": "roxonn-code.directFocusChatInput",
				"key": "ctrl+shift+k",
				"mac": "cmd+shift+k",
				"when": "true"
			}
		],
		"menus": {
			"editor/context": [
				{
					"submenu": "roxonn-code.contextMenu",
					"group": "navigation"
				}
			],
			"roxonn-code.contextMenu": [
				{
					"command": "roxonn-code.explainCode",
					"group": "1_actions@1"
				},
				{
					"command": "roxonn-code.fixCode",
					"group": "1_actions@2"
				},
				{
					"command": "roxonn-code.improveCode",
					"group": "1_actions@3"
				},
				{
					"command": "roxonn-code.addToContext",
					"group": "1_actions@4"
				}
			],
			"terminal/context": [
				{
					"submenu": "roxonn-code.terminalMenu",
					"group": "navigation"
				}
			],
			"roxonn-code.terminalMenu": [
				{
					"command": "roxonn-code.terminalAddToContext",
					"group": "1_actions@1"
				},
				{
					"command": "roxonn-code.terminalFixCommand",
					"group": "1_actions@2"
				},
				{
					"command": "roxonn-code.terminalExplainCommand",
					"group": "1_actions@3"
				}
			],
			"view/title": [
				{
					"command": "roxonn-code.plusButtonClicked",
					"group": "navigation@1",
					"when": "view == roxonn-code.SidebarProvider"
				},
				{
					"command": "roxonn-code.promptsButtonClicked",
					"group": "navigation@2",
					"when": "view == roxonn-code.SidebarProvider"
				},
				{
					"command": "roxonn-code.historyButtonClicked",
					"group": "navigation@3",
					"when": "view == roxonn-code.SidebarProvider"
				},
				{
					"command": "roxonn-code.profileButtonClicked",
					"group": "navigation@4",
					"when": "view == roxonn-code.SidebarProvider"
				},
				{
					"command": "roxonn-code.settingsButtonClicked",
					"group": "navigation@5",
					"when": "view == roxonn-code.SidebarProvider"
				},
				{
					"command": "roxonn-code.popoutButtonClicked",
					"group": "navigation@6",
					"when": "view == roxonn-code.SidebarProvider"
				},
				{
					"command": "roxonn-code.helpButtonClicked",
					"group": "navigation@7",
					"when": "false && view == roxonn-code.SidebarProvider"
				}
			],
			"editor/title": [
				{
					"command": "roxonn-code.plusButtonClicked",
					"group": "navigation@1",
					"when": "activeWebviewPanelId == roxonn-code.TabPanelProvider"
				},
				{
					"command": "roxonn-code.promptsButtonClicked",
					"group": "navigation@2",
					"when": "activeWebviewPanelId == roxonn-code.TabPanelProvider"
				},
				{
					"command": "roxonn-code.historyButtonClicked",
					"group": "navigation@3",
					"when": "activeWebviewPanelId == roxonn-code.TabPanelProvider"
				},
				{
					"command": "roxonn-code.popoutButtonClicked",
					"group": "navigation@4",
					"when": "activeWebviewPanelId == roxonn-code.TabPanelProvider"
				},
				{
					"command": "roxonn-code.settingsButtonClicked",
					"group": "navigation@5",
					"when": "activeWebviewPanelId == roxonn-code.TabPanelProvider"
				},
				{
					"command": "roxonn-code.helpButtonClicked",
					"group": "navigation@6",
					"when": "activeWebviewPanelId == roxonn-code.TabPanelProvider"
				}
			]
		},
		"submenus": [
			{
				"id": "roxonn-code.contextMenu",
				"label": "%views.contextMenu.label%"
			},
			{
				"id": "roxonn-code.terminalMenu",
				"label": "%views.terminalMenu.label%"
			}
		],
		"configuration": {
			"title": "%configuration.title%",
			"properties": {
				"roxonn-code.allowedCommands": {
					"type": "array",
					"items": {
						"type": "string"
					},
					"default": [
						"npm test",
						"npm install",
						"tsc",
						"git log",
						"git diff",
						"git show"
					],
					"description": "%commands.allowedCommands.description%"
				},
				"roxonn-code.vsCodeLmModelSelector": {
					"type": "object",
					"properties": {
						"vendor": {
							"type": "string",
							"description": "%settings.vsCodeLmModelSelector.vendor.description%"
						},
						"family": {
							"type": "string",
							"description": "%settings.vsCodeLmModelSelector.family.description%"
						}
					},
					"description": "%settings.vsCodeLmModelSelector.description%"
				},
				"roxonn-code.customStoragePath": {
					"type": "string",
					"default": "",
					"description": "%settings.customStoragePath.description%"
				}
			}
		}
	},
	"scripts": {
		"lint": "eslint . --ext=ts --max-warnings=0",
		"check-types": "tsc --noEmit",
		"pretest": "pnpm bundle",
		"test": "jest -w=40% && vitest run",
		"format": "prettier --write .",
		"bundle": "pnpm clean && pnpm --filter @roo-code/build build && node esbuild.mjs",
		"build": "pnpm bundle --production && pnpm --filter @roo-code/vscode-webview build",
		"build:development": "pnpm bundle && pnpm --filter @roo-code/vscode-webview build",
		"publish:marketplace": "vsce publish --no-dependencies && ovsx publish --no-dependencies",
		"vscode:prepublish": "pnpm build",
		"vsix": "mkdirp ../bin && npx vsce package --no-dependencies --out ../bin",
		"watch:esbuild": "pnpm bundle --watch",
		"watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
		"generate-types": "tsx scripts/generate-types.mts",
		"clean": "rimraf README.md CHANGELOG.md LICENSE dist webview-ui out .turbo"
	},
	"dependencies": {
		"@anthropic-ai/bedrock-sdk": "^0.22.0",
		"@anthropic-ai/sdk": "^0.51.0",
		"@anthropic-ai/vertex-sdk": "^0.11.3",
		"@aws-sdk/client-bedrock-runtime": "^3.812.0",
		"@aws-sdk/credential-providers": "^3.806.0",
		"@google/genai": "^0.13.0",
		"@mistralai/mistralai": "^1.6.0",
		"@modelcontextprotocol/sdk": "^1.9.0",
		"@vscode/codicons": "^0.0.36",
		"axios": "^1.7.4",
		"cheerio": "^1.0.0",
		"chokidar": "^4.0.1",
		"clone-deep": "^4.0.1",
		"default-shell": "^2.2.0",
		"delay": "^6.0.0",
		"diff": "^5.2.0",
		"diff-match-patch": "^1.0.5",
		"fast-deep-equal": "^3.1.3",
		"fast-xml-parser": "^4.5.1",
		"fastest-levenshtein": "^1.0.16",
		"fzf": "^0.5.2",
		"get-folder-size": "^5.0.0",
		"google-auth-library": "^9.15.1",
		"i18next": "^24.2.2",
		"ignore": "^7.0.3",
		"isbinaryfile": "^5.0.2",
		"mammoth": "^1.8.0",
		"monaco-vscode-textmate-theme-converter": "^0.1.7",
		"node-cache": "^5.1.2",
		"node-ipc": "^12.0.0",
		"openai": "^4.100.0",
		"os-name": "^6.0.0",
		"p-wait-for": "^5.0.2",
		"pdf-parse": "^1.1.1",
		"pkce-challenge": "^4.1.0",
		"posthog-node": "^4.7.0",
		"pretty-bytes": "^6.1.1",
		"ps-tree": "^1.2.0",
		"puppeteer-chromium-resolver": "^23.0.0",
		"puppeteer-core": "^23.4.0",
		"reconnecting-eventsource": "^1.6.4",
		"sanitize-filename": "^1.6.3",
		"say": "^0.16.0",
		"serialize-error": "^11.0.3",
		"simple-git": "^3.27.0",
		"sound-play": "^1.1.0",
		"string-similarity": "^4.0.4",
		"strip-ansi": "^7.1.0",
		"strip-bom": "^5.0.0",
		"tiktoken": "^1.0.21",
		"tmp": "^0.2.3",
		"tree-sitter-wasms": "^0.1.11",
		"turndown": "^7.2.0",
		"vscode-material-icons": "^0.1.1",
		"web-tree-sitter": "^0.22.6",
		"workerpool": "^9.2.0",
		"yaml": "^2.8.0",
		"zod": "^3.24.2"
	},
	"devDependencies": {
		"@jest/globals": "^29.7.0",
		"@roo-code/config-eslint": "workspace:^",
		"@roo-code/config-typescript": "workspace:^",
		"@roo-code/build": "workspace:^",
		"@types/clone-deep": "^4.0.4",
		"@types/debug": "^4.1.12",
		"@types/diff": "^5.2.1",
		"@types/diff-match-patch": "^1.0.36",
		"@types/glob": "^8.1.0",
		"@types/jest": "^29.5.14",
		"@types/mocha": "^10.0.10",
		"@types/node": "20.x",
		"@types/node-cache": "^4.1.3",
		"@types/node-ipc": "^9.2.3",
		"@types/ps-tree": "^1.1.6",
		"@types/string-similarity": "^4.0.2",
		"@types/tmp": "^0.2.6",
		"@types/turndown": "^5.0.5",
		"@types/vscode": "^1.84.0",
		"@vscode/test-electron": "^2.5.2",
		"@vscode/vsce": "3.3.2",
		"esbuild": "^0.25.0",
		"execa": "^9.5.2",
		"glob": "^11.0.1",
		"jest": "^29.7.0",
		"jest-simple-dot-reporter": "^1.0.5",
		"mkdirp": "^3.0.1",
		"nock": "^14.0.4",
		"npm-run-all2": "^8.0.1",
		"ovsx": "0.10.2",
		"rimraf": "^6.0.1",
		"ts-jest": "^29.2.5",
		"tsup": "^8.4.0",
		"tsx": "^4.19.3",
		"typescript": "5.8.3",
		"vitest": "^3.1.3",
		"zod-to-ts": "^1.2.0"
	}
}
